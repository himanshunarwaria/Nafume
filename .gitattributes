# Normalize line endings for Shopify theme files
* text=auto eol=lf

*.liquid text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.md     text eol=lf

# Binary assets (images, fonts) — do not touch
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
