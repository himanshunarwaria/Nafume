<aside id="cart-drawer"
       class="drawer drawer--right cart-drawer"
       role="dialog"
       aria-modal="true"
       aria-label="Shopping cart"
       aria-hidden="true">

  <div class="drawer__head">
    <h2 class="drawer__title">
      Your Cart
      {%- if cart.item_count > 0 -%}
        <span class="drawer__title-count">({{ cart.item_count }})</span>
      {%- endif -%}
    </h2>
    <button class="drawer__close" data-drawer-close aria-label="Close cart">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="18" height="18">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  {%- comment -%}
    The content below is the refreshable region. When the AJAX cart updates,
    /?sections=cart-drawer-content re-renders sections/cart-drawer-content.liquid
    and we swap innerHTML of #cart-drawer-content.
  {%- endcomment -%}
  <div id="cart-drawer-content">
    {%- render 'cart-drawer-content' -%}
  </div>

</aside>
