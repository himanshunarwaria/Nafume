<div id="quick-view-overlay" class="modal-overlay" aria-hidden="true"></div>

<div id="quick-view-modal"
     class="modal"
     role="dialog"
     aria-modal="true"
     aria-label="Quick view"
     aria-hidden="true">

  <button class="modal__close" aria-label="Close quick view">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <div class="modal__gallery">
    <div class="skeleton" style="width:100%;height:100%;min-height:300px"></div>
  </div>

  <div class="modal__body">
    <div class="skeleton" style="width:70%;height:20px;margin-bottom:12px"></div>
    <div class="skeleton" style="width:45%;height:14px"></div>
  </div>

</div>
