{%- comment -%}
  Quick-view modal — singleton rendered once in layout/theme.liquid.
  Populated entirely by assets/quick-view.js via /products/{handle}.js.
  Trigger: any [data-quick-view="handle"] button on the page.
{%- endcomment -%}

{{- 'quick-view.css' | asset_url | stylesheet_tag -}}

<div
  id="QVModal"
  class="qv"
  role="dialog"
  aria-modal="true"
  aria-labelledby="QVTitle"
  aria-hidden="true"
  hidden>

  <div class="qv__backdrop" data-qv-close aria-hidden="true"></div>

  <div class="qv__panel">

    {%- comment -%} Close button ─── {%- endcomment -%}
    <button
      class="qv__close"
      type="button"
      data-qv-close
      aria-label="Close quick view">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.5" width="18" height="18" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    {%- comment -%} Loading state ─── {%- endcomment -%}
    <div class="qv__loading" id="QVLoading" aria-label="Loading product" role="status">
      <div class="qv__spinner" aria-hidden="true"></div>
    </div>

    {%- comment -%} Error state ─── {%- endcomment -%}
    <div class="qv__error" id="QVError" hidden>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.5" width="32" height="32" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 8v4M12 16h.01"/>
      </svg>
      <p class="qv__error-msg">Couldn't load this product.</p>
      <button type="button" class="qv__error-retry" id="QVRetry">Try Again</button>
    </div>

    {%- comment -%} Content body ─── {%- endcomment -%}
    <div class="qv__body" id="QVBody" hidden>

      {%- comment -%} ── Gallery (left) ─── {%- endcomment -%}
      <div class="qv__gallery">
        <div class="qv__img-wrap">
          <img
            class="qv__img"
            id="QVImg"
            src=""
            alt=""
            width="600"
            height="750"
            loading="eager">
        </div>
        <div class="qv__thumbs" id="QVThumbs" hidden aria-label="Product images"></div>
      </div>

      {%- comment -%} ── Info (right) ─── {%- endcomment -%}
      <div class="qv__info">

        {%- comment -%} Meta tags: fragrance family + gender ─── {%- endcomment -%}
        <div class="qv__meta" id="QVMeta" aria-label="Product details"></div>

        <h2 class="qv__title" id="QVTitle"></h2>

        {%- comment -%} Price + discount ─── {%- endcomment -%}
        <div class="qv__price-block" id="QVPriceBlock" aria-live="polite"></div>

        {%- comment -%} Short description ─── {%- endcomment -%}
        <p class="qv__desc" id="QVDesc"></p>

        {%- comment -%} Variant selector (shown only when variants > 1) ─── {%- endcomment -%}
        <div class="qv__variants" id="QVVariants" aria-live="polite"></div>

        {%- comment -%} Qty + ATC ─── {%- endcomment -%}
        <div class="qv__form">

          <div class="qv__qty" role="group" aria-label="Quantity">
            <button
              type="button"
              class="qv__qty-btn"
              data-qv-qty="-1"
              aria-label="Decrease quantity">−</button>
            <input
              type="number"
              class="qv__qty-input"
              id="QVQty"
              value="1"
              min="1"
              max="99"
              aria-label="Quantity">
            <button
              type="button"
              class="qv__qty-btn"
              data-qv-qty="1"
              aria-label="Increase quantity">+</button>
          </div>

          <button
            type="button"
            class="qv__atc"
            id="QVATCBtn"
            aria-live="polite">
            <span class="qv__atc-label">Add to Cart</span>
            <span class="qv__atc-spinner" aria-hidden="true"></span>
          </button>

        </div>

        <a class="qv__view-full" id="QVViewFull" href="#">
          View Full Details
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor"
               stroke-width="1.5" width="12" height="12" aria-hidden="true">
            <path d="M2.5 7h9M7 2.5L11.5 7 7 11.5"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

      </div>
    </div>

  </div>
</div>
