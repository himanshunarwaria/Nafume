{%- comment -%}
  Usage:
    {%- render 'social-icons',
        instagram: section.settings.social_instagram,
        facebook:  section.settings.social_facebook,
        youtube:   section.settings.social_youtube,
        twitter:   section.settings.social_twitter,
        pinterest: section.settings.social_pinterest,
        size: 18 -%}
  All URL params are optional. Renders nothing if all are blank.
{%- endcomment -%}

{%- liquid
  assign _size = size | default: 18
  assign _has  = false
  if instagram != blank or facebook != blank or youtube != blank or twitter != blank or pinterest != blank
    assign _has = true
  endif
-%}

{%- if _has -%}
<ul class="social-icons" aria-label="Follow us on social media">

  {%- if instagram != blank -%}
  <li>
    <a href="{{ instagram }}" class="social-icon" target="_blank" rel="noopener noreferrer"
       aria-label="{{ 'general.social.instagram' | t | default: 'Instagram' }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           width="{{ _size }}" height="{{ _size }}" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4"/>
        <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
      </svg>
    </a>
  </li>
  {%- endif -%}

  {%- if facebook != blank -%}
  <li>
    <a href="{{ facebook }}" class="social-icon" target="_blank" rel="noopener noreferrer"
       aria-label="{{ 'general.social.facebook' | t | default: 'Facebook' }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           width="{{ _size }}" height="{{ _size }}" aria-hidden="true">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
      </svg>
    </a>
  </li>
  {%- endif -%}

  {%- if youtube != blank -%}
  <li>
    <a href="{{ youtube }}" class="social-icon" target="_blank" rel="noopener noreferrer"
       aria-label="{{ 'general.social.youtube' | t | default: 'YouTube' }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           width="{{ _size }}" height="{{ _size }}" aria-hidden="true">
        <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
        <polygon points="9.75,15.02 15.5,12 9.75,8.98 9.75,15.02" fill="currentColor" stroke="none"/>
      </svg>
    </a>
  </li>
  {%- endif -%}

  {%- if twitter != blank -%}
  <li>
    <a href="{{ twitter }}" class="social-icon" target="_blank" rel="noopener noreferrer"
       aria-label="{{ 'general.social.twitter' | t | default: 'X (Twitter)' }}">
      <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"
           width="{{ _size }}" height="{{ _size }}" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
  </li>
  {%- endif -%}

  {%- if pinterest != blank -%}
  <li>
    <a href="{{ pinterest }}" class="social-icon" target="_blank" rel="noopener noreferrer"
       aria-label="{{ 'general.social.pinterest' | t | default: 'Pinterest' }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           width="{{ _size }}" height="{{ _size }}" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.852 0 1.265.64 1.265 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.868 3.137-4.568 0-2.39-1.718-4.059-4.17-4.059-2.837 0-4.502 2.128-4.502 4.328 0 .856.33 1.774.741 2.276a.3.3 0 0 1 .069.285c-.076.312-.244.995-.277 1.134-.044.183-.145.222-.335.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
      </svg>
    </a>
  </li>
  {%- endif -%}

</ul>
{%- endif -%}
