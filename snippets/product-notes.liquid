{%- comment -%}
  Fragrance notes grid: Top / Middle / Base.
  Params:
    product → product object

  Metafields read:
    custom.top_notes    → single_line_text or list.single_line_text — e.g. "Rose, Bergamot"
    custom.middle_notes → same
    custom.base_notes   → same
{%- endcomment -%}

{%- liquid
  assign top_notes    = product.metafields.custom.top_notes.value
  assign middle_notes = product.metafields.custom.middle_notes.value
  assign base_notes   = product.metafields.custom.base_notes.value

  comment
    Handle both list metafields (returns an array) and text metafields (returns a string).
  endcomment
  if top_notes.first
    assign top_notes = top_notes | join: ', '
  endif
  if middle_notes.first
    assign middle_notes = middle_notes | join: ', '
  endif
  if base_notes.first
    assign base_notes = base_notes | join: ', '
  endif
-%}

{%- if top_notes != blank or middle_notes != blank or base_notes != blank -%}

<div class="notes-grid">

  {%- if top_notes != blank -%}
    {%- assign top_items = top_notes | split: ',' -%}
    <div class="notes-group notes-group--top">
      <div class="notes-group__icon" aria-hidden="true">
        {%- comment -%} Sun / citrus burst — represents the initial impression {%- endcomment -%}
        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor"
             stroke-width="1.4" width="28" height="28" aria-hidden="true">
          <circle cx="16" cy="16" r="5"/>
          <line x1="16" y1="3" x2="16" y2="7"/>
          <line x1="16" y1="25" x2="16" y2="29"/>
          <line x1="3" y1="16" x2="7" y2="16"/>
          <line x1="25" y1="16" x2="29" y2="16"/>
          <line x1="7.05" y1="7.05" x2="9.88" y2="9.88"/>
          <line x1="22.12" y1="22.12" x2="24.95" y2="24.95"/>
          <line x1="7.05" y1="24.95" x2="9.88" y2="22.12"/>
          <line x1="22.12" y1="9.88" x2="24.95" y2="7.05"/>
        </svg>
      </div>
      <p class="notes-group__label">Top Notes</p>
      <div class="notes-group__items">
        {%- for item in top_items -%}
          <span class="notes-group__chip">{{ item | strip }}</span>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if middle_notes != blank -%}
    {%- assign middle_items = middle_notes | split: ',' -%}
    <div class="notes-group notes-group--middle">
      <div class="notes-group__icon" aria-hidden="true">
        {%- comment -%} Flower bloom — represents the heart notes {%- endcomment -%}
        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor"
             stroke-width="1.4" width="28" height="28" aria-hidden="true">
          <circle cx="16" cy="16" r="3.5"/>
          <ellipse cx="16" cy="8" rx="3" ry="4.5"/>
          <ellipse cx="16" cy="8" rx="3" ry="4.5" transform="rotate(60 16 16)"/>
          <ellipse cx="16" cy="8" rx="3" ry="4.5" transform="rotate(120 16 16)"/>
          <ellipse cx="16" cy="8" rx="3" ry="4.5" transform="rotate(180 16 16)"/>
          <ellipse cx="16" cy="8" rx="3" ry="4.5" transform="rotate(240 16 16)"/>
          <ellipse cx="16" cy="8" rx="3" ry="4.5" transform="rotate(300 16 16)"/>
        </svg>
      </div>
      <p class="notes-group__label">Heart Notes</p>
      <div class="notes-group__items">
        {%- for item in middle_items -%}
          <span class="notes-group__chip">{{ item | strip }}</span>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if base_notes != blank -%}
    {%- assign base_items = base_notes | split: ',' -%}
    <div class="notes-group notes-group--base">
      <div class="notes-group__icon" aria-hidden="true">
        {%- comment -%} Drop / wood — represents the lasting base {%- endcomment -%}
        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor"
             stroke-width="1.4" width="28" height="28" aria-hidden="true">
          <path d="M16 4 C16 4, 6 16, 6 21 a10 10 0 0 0 20 0 C26 16, 16 4, 16 4z"
                stroke-linejoin="round"/>
          <path d="M10 23 Q13 20, 16 22" stroke-linecap="round" opacity="0.5"/>
        </svg>
      </div>
      <p class="notes-group__label">Base Notes</p>
      <div class="notes-group__items">
        {%- for item in base_items -%}
          <span class="notes-group__chip">{{ item | strip }}</span>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>
{%- endif -%}
