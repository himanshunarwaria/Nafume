<aside id="account-drawer"
       class="drawer drawer--right account-drawer"
       role="dialog"
       aria-modal="true"
       aria-label="Account"
       aria-hidden="true">

  <div class="drawer__head">
    <h2 class="drawer__title">
      {%- if customer -%}My Account{%- else -%}Welcome{%- endif -%}
    </h2>
    <button class="drawer__close" data-drawer-close aria-label="Close account panel">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="18" height="18">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <div class="drawer__body">

    {%- if customer -%}
      {%- comment -%} ── Logged-in state ── {%- endcomment -%}
      <div class="account-welcome">
        <div class="account-welcome__avatar" aria-hidden="true">
          {{- customer.first_name | default: customer.email | slice: 0 | upcase -}}
        </div>
        <div>
          <p class="account-welcome__greeting">Welcome back</p>
          <p class="account-welcome__name">{{ customer.first_name | default: customer.email }}</p>
        </div>
      </div>

      <nav class="account-links" aria-label="Account navigation">
        <a href="{{ routes.account_url }}" class="account-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/>
          </svg>
          My Orders
        </a>
        <a href="{{ routes.account_url }}/addresses" class="account-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Addresses
        </a>
        <a href="{{ routes.account_url }}" class="account-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
            <circle cx="12" cy="8" r="3.5"/><path d="M4 20c0-3.87 3.582-7 8-7s8 3.13 8 7" stroke-linecap="round"/>
          </svg>
          Account Details
        </a>
        <a href="{{ routes.account_logout_url }}" class="account-link account-link--danger">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/>
          </svg>
          Sign Out
        </a>
      </nav>

    {%- else -%}
      {%- comment -%} ── Guest state — Login / Register tabs ── {%- endcomment -%}

      <div data-account-tabs>

        {%- comment -%} Tab navigation {%- endcomment -%}
        <div class="account-tabs__nav" role="tablist" aria-label="Account">
          <button class="account-tab__btn is-active"
                  role="tab"
                  id="tab-btn-login"
                  aria-selected="true"
                  aria-controls="tab-login"
                  data-tab="login">
            Sign In
          </button>
          <button class="account-tab__btn"
                  role="tab"
                  id="tab-btn-register"
                  aria-selected="false"
                  aria-controls="tab-register"
                  data-tab="register">
            Create Account
          </button>
        </div>

        {%- comment -%} Login panel {%- endcomment -%}
        <div class="account-tab__panel is-active"
             id="tab-login"
             role="tabpanel"
             aria-labelledby="tab-btn-login"
             data-tab-panel="login">

          <form method="post" action="/account/login" class="account-form" novalidate>
            <input type="hidden" name="form_type" value="customer_login">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="return_to" value="{{ request.path }}">

            <div class="account-form__field">
              <label class="account-form__label" for="login-email">Email</label>
              <input class="account-form__input"
                     type="email"
                     id="login-email"
                     name="customer[email]"
                     autocomplete="email"
                     autocapitalize="off"
                     required>
            </div>

            <div class="account-form__field">
              <div class="account-form__label-row">
                <label class="account-form__label" for="login-password">Password</label>
                <button type="button" class="account-form__link" data-show-reset>Forgot password?</button>
              </div>
              <div class="account-form__input-wrap">
                <input class="account-form__input"
                       type="password"
                       id="login-password"
                       name="customer[password]"
                       autocomplete="current-password"
                       required>
                <button type="button" class="account-form__toggle-pw" aria-label="Show password" data-toggle-pw>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                  </svg>
                </button>
              </div>
            </div>

            <button type="submit" class="btn btn--solid btn--full" style="margin-top:var(--sp-6)">
              Sign In
            </button>
          </form>

        </div>

        {%- comment -%} Register panel {%- endcomment -%}
        <div class="account-tab__panel"
             id="tab-register"
             role="tabpanel"
             aria-labelledby="tab-btn-register"
             data-tab-panel="register"
             hidden>

          <form method="post" action="/account" class="account-form" novalidate data-register-form>
            <input type="hidden" name="form_type" value="create_customer">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="return_to" value="{{ request.path }}">

            <div class="account-form__row">
              <div class="account-form__field">
                <label class="account-form__label" for="reg-first-name">First name</label>
                <input class="account-form__input"
                       type="text"
                       id="reg-first-name"
                       name="customer[first_name]"
                       autocomplete="given-name"
                       required>
              </div>
              <div class="account-form__field">
                <label class="account-form__label" for="reg-last-name">Last name</label>
                <input class="account-form__input"
                       type="text"
                       id="reg-last-name"
                       name="customer[last_name]"
                       autocomplete="family-name"
                       required>
              </div>
            </div>

            <div class="account-form__field">
              <label class="account-form__label" for="reg-email">Email</label>
              <input class="account-form__input"
                     type="email"
                     id="reg-email"
                     name="customer[email]"
                     autocomplete="email"
                     autocapitalize="off"
                     required>
            </div>

            <div class="account-form__field">
              <label class="account-form__label" for="reg-password">Password</label>
              <div class="account-form__input-wrap">
                <input class="account-form__input"
                       type="password"
                       id="reg-password"
                       name="customer[password]"
                       autocomplete="new-password"
                       minlength="5"
                       required>
                <button type="button" class="account-form__toggle-pw" aria-label="Show password" data-toggle-pw>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                  </svg>
                </button>
              </div>
            </div>

            <label class="account-form__check">
              <input type="checkbox" name="customer[accepts_marketing]" value="1" class="account-form__checkbox">
              <span>Send me exclusive offers and updates</span>
            </label>

            <label class="account-form__check account-form__check--required">
              <input type="checkbox" required class="account-form__checkbox" data-terms>
              <span>I agree to the <a href="/policies/terms-of-service" target="_blank" rel="noopener">Terms of Service</a> and <a href="/policies/privacy-policy" target="_blank" rel="noopener">Privacy Policy</a></span>
            </label>

            <button type="submit" class="btn btn--solid btn--full" style="margin-top:var(--sp-6)">
              Create Account
            </button>
          </form>

        </div>
      </div>

      {%- comment -%} ── Reset password panel (hidden by default) ── {%- endcomment -%}
      <div class="account-reset" data-reset-panel hidden>

        <button type="button" class="account-reset__back" data-hide-reset aria-label="Back to sign in">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="14" height="14">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
          Back to sign in
        </button>

        <h3 class="account-reset__heading">Reset your password</h3>
        <p class="account-reset__desc">We'll send a link to your email to reset your password.</p>

        <form method="post" action="/account/recover" class="account-form">
          <input type="hidden" name="form_type" value="recover_customer_password">
          <input type="hidden" name="utf8" value="✓">

          <div class="account-form__field">
            <label class="account-form__label" for="reset-email">Email address</label>
            <input class="account-form__input"
                   type="email"
                   id="reset-email"
                   name="email"
                   autocomplete="email"
                   autocapitalize="off"
                   required>
          </div>

          <button type="submit" class="btn btn--solid btn--full" style="margin-top:var(--sp-6)">
            Send reset link
          </button>
        </form>

      </div>

    {%- endif -%}

  </div>

</aside>
