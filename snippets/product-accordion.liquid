{%- comment -%}
  Renders a single collapsible accordion row.
  Params:
    accordion_title   → String (required)
    accordion_content → HTML string (skips render if blank)
    accordion_open    → Boolean — starts open (default: false)
{%- endcomment -%}

{%- if accordion_content != blank -%}

<details
  class="accordion{% if accordion_open %} accordion--open{% endif %}"
  data-accordion>

  <summary class="accordion__head">
    <span class="accordion__title">{{ accordion_title }}</span>
    <span class="accordion__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.5" width="16" height="16">
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </span>
  </summary>

  <div class="accordion__body" data-accordion-body>
    <div class="accordion__content rte">
      {{ accordion_content }}
    </div>
  </div>

</details>

{%- endif -%}
