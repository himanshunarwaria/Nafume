<aside id="search-drawer"
       class="drawer drawer--right search-drawer"
       role="dialog"
       aria-modal="true"
       aria-label="Search"
       aria-hidden="true">

  <div class="drawer__head">
    <h2 class="drawer__title">Search our store</h2>
    <button class="drawer__close" data-drawer-close aria-label="Close search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="18" height="18">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <div class="search-drawer__body">

    <form action="/search" method="get" role="search" class="search-form" data-search-form>
      <div class="search-form__field">
        <svg class="search-form__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="18" height="18">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.4-4.4" stroke-linecap="round"/>
        </svg>
        <input
          class="search-form__input"
          type="search"
          name="q"
          placeholder="Search fragrances, notes, moods…"
          autocomplete="off"
          spellcheck="false"
          data-search-input
          aria-label="Search products"
          aria-autocomplete="list"
          aria-controls="search-results-list">
        <button type="button" class="search-form__clear" data-search-clear hidden aria-label="Clear search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" width="14" height="14">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <input type="hidden" name="type" value="product">
    </form>

    <div class="search-results" id="search-results-list" aria-live="polite" aria-label="Search results" data-search-results>

      {%- comment -%} Default state — popular categories {%- endcomment -%}
      <div class="search-hints" data-search-hints>
        <p class="search-hints__label">Popular</p>
        <div class="search-hints__tags">
          <a href="/collections/new-arrivals" class="search-tag">New Arrivals</a>
          <a href="/collections/bestsellers" class="search-tag">Best Sellers</a>
          <a href="/collections/him" class="search-tag">For Him</a>
          <a href="/collections/her" class="search-tag">For Her</a>
          <a href="/collections/discovery-sets" class="search-tag">Discovery Sets</a>
          <a href="/collections/gifting" class="search-tag">Gifting</a>
        </div>
      </div>

    </div>

    <a href="/search?q=" class="search-more" data-search-more hidden aria-live="polite">
      View all results
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="14" height="14">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

  </div>

</aside>
