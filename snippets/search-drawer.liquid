<aside id="search-drawer"
       class="drawer drawer--right"
       role="dialog"
       aria-modal="true"
       aria-label="Search"
       aria-hidden="true">

  <div class="drawer__head">
    <h2 class="drawer__title">Search</h2>
    <button class="drawer__close" data-drawer-close aria-label="Close search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <form action="/search" method="get" role="search">
    <div class="search-form">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="search-form__input"
        type="search"
        name="q"
        placeholder="Search fragrances…"
        autocomplete="off"
        aria-label="Search products">
      <input type="hidden" name="type" value="product">
    </div>
  </form>

  <div class="search-results" aria-live="polite" aria-label="Search results">
    <p class="search-results__label" style="margin-top:var(--sp-6)">Start typing to discover fragrances…</p>
  </div>

</aside>
