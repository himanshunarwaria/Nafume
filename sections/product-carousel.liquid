{{- 'product-carousel.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign col = collections[section.settings.collection]
  assign limit = section.settings.product_limit | default: 8
  assign cols  = section.settings.products_per_row | default: 4
  assign has_products = col != blank and col.products.size > 0
-%}

{%- if has_products -%}

<section
  id="pc-{{ section.id }}"
  class="product-carousel pc--cols-{{ cols }} pc--align-{{ section.settings.text_align }}"
  style="--pc-bg: {{ section.settings.bg_color }};"
  data-pc
  aria-labelledby="pc-{{ section.id }}-heading">

  <div class="pc__container container">

    {%- comment -%} Section header {%- endcomment -%}
    <header class="pc__header">
      <div class="pc__header-text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="pc__eyebrow eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="pc__heading" id="pc-{{ section.id }}-heading">
          {{ section.settings.heading | default: col.title }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="pc__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Desktop arrow nav {%- endcomment -%}
      <div class="pc__nav" aria-label="Carousel controls">
        <button
          class="pc__nav-btn pc__nav-btn--prev"
          aria-label="Previous products"
          aria-controls="pc-{{ section.id }}-track"
          disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.5" aria-hidden="true" width="18" height="18">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button
          class="pc__nav-btn pc__nav-btn--next"
          aria-label="Next products"
          aria-controls="pc-{{ section.id }}-track">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.5" aria-hidden="true" width="18" height="18">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    </header>

    {%- comment -%} Scroll track {%- endcomment -%}
    <div class="pc__viewport">
      <ul
        id="pc-{{ section.id }}-track"
        class="pc__track"
        role="list"
        data-pc-track>

        {%- for product in col.products limit: limit -%}
          <li class="pc__slide">
            {%- render 'product-card',
              product:        product,
              image_ratio:    'portrait',
              lazy:           true,
              index:          forloop.index,
              show_quick_add: true,
              show_desc:      false,
              show_sale_pct:  true
            -%}
          </li>
        {%- endfor -%}

      </ul>
    </div>

    {%- comment -%} Progress bar {%- endcomment -%}
    <div class="pc__progress" aria-hidden="true">
      <div class="pc__progress-fill" data-pc-fill></div>
    </div>

    {%- comment -%} Optional CTA {%- endcomment -%}
    {%- if section.settings.show_cta and section.settings.cta_label != blank -%}
      <div class="pc__cta-wrap">
        <a
          href="{{ section.settings.cta_url | default: col.url }}"
          class="pc__cta">
          {{ section.settings.cta_label }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.5" aria-hidden="true" width="14" height="14">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>

</section>

{%- endif -%}

<script src="{{ 'product-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "product-carousel-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Small label above the heading."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Launches"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "info": "Optional line below the heading."
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 4,
      "max": 16,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Header alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button text",
      "default": "Discover the Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL",
      "info": "Falls back to the collection URL if blank."
    }
  ],
  "presets": [
    {
      "name": "New Launches",
      "settings": {
        "eyebrow": "Just Arrived",
        "heading": "New Launches",
        "subheading": "The latest additions to our collection.",
        "product_limit": 8,
        "products_per_row": "4",
        "text_align": "left",
        "show_cta": true,
        "cta_label": "Discover New Arrivals"
      }
    },
    {
      "name": "Best Sellers",
      "settings": {
        "eyebrow": "Most Loved",
        "heading": "Best Sellers",
        "subheading": "Fragrances our customers keep coming back for.",
        "product_limit": 8,
        "products_per_row": "4",
        "text_align": "left",
        "show_cta": true,
        "cta_label": "Shop Best Sellers"
      }
    },
    {
      "name": "For Him",
      "settings": {
        "eyebrow": "Masculine",
        "heading": "For Him",
        "subheading": "Bold. Intense. Unforgettable.",
        "product_limit": 8,
        "products_per_row": "4",
        "text_align": "left",
        "show_cta": true,
        "cta_label": "Explore Men's Collection"
      }
    },
    {
      "name": "For Her",
      "settings": {
        "eyebrow": "Feminine",
        "heading": "For Her",
        "subheading": "Floral. Sensual. Timeless.",
        "product_limit": 8,
        "products_per_row": "4",
        "text_align": "left",
        "show_cta": true,
        "cta_label": "Explore Women's Collection"
      }
    },
    {
      "name": "Discovery Sets",
      "settings": {
        "eyebrow": "Explore",
        "heading": "Discovery Sets",
        "subheading": "Find your signature scent with our curated sets.",
        "product_limit": 6,
        "products_per_row": "3",
        "text_align": "center",
        "show_cta": true,
        "cta_label": "Shop Discovery Sets"
      }
    }
  ]
}
{% endschema %}
