{%- liquid
  assign carousel_collection = collections[section.settings.collection]
  assign products_limit = section.settings.products_to_show | default: 8
-%}

{%- if carousel_collection != blank and carousel_collection.products.size > 0 -%}
<section class="section-padding product-carousel" data-product-carousel aria-labelledby="carousel-{{ section.id }}-title">
  <div class="container">

    <div class="carousel__header">
      <div class="carousel__header-text">
        {%- if section.settings.subtitle != blank -%}
          <span class="eyebrow">{{ section.settings.subtitle }}</span>
        {%- endif -%}
        <h2 class="section-title section-title--left" id="carousel-{{ section.id }}-title">
          {{ section.settings.heading | default: carousel_collection.title }}
        </h2>
      </div>
      <div style="display:flex;align-items:center;gap:var(--sp-4)">
        {%- if section.settings.view_all_text != blank -%}
          <a href="{{ carousel_collection.url }}" class="btn btn--ghost">
            {{ section.settings.view_all_text }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
        <div class="carousel__nav">
          <button class="carousel__nav-btn carousel__nav-btn--prev" aria-label="Previous products">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <button class="carousel__nav-btn carousel__nav-btn--next" aria-label="Next products">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="carousel__viewport">
      <div class="carousel__track">
        {%- for product in carousel_collection.products limit: products_limit -%}
          <div class="carousel__slide">
            {% render 'product-card', product: product, show_vendor: false %}
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Product Carousel",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Eyebrow / subtitle",
      "default": "Discover"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "New Launches"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 16,
      "step": 2,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "View All"
    }
  ],
  "presets": [
    { "name": "Product Carousel", "settings": { "heading": "New Launches", "subtitle": "Discover" } }
  ]
}
{% endschema %}
