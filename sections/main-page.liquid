<div class="container section-padding">
  <div style="max-width:800px;margin:0 auto">
    <h1 class="section-title" style="text-align:left;margin-bottom:var(--space-6)">{{ page.title }}</h1>
    <div class="rte" style="line-height:1.8;color:var(--color-text-muted)">
      {{ page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page Content",
  "settings": [],
  "presets": [{ "name": "Page Content" }]
}
{% endschema %}
