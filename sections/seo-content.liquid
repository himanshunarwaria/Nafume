<section class="section-padding" style="background:var(--color-bg-alt)" aria-labelledby="seo-content-heading">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <h2 class="section-title" id="seo-content-heading" style="margin-bottom:var(--space-8)">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="accordion" data-multi="true" style="max-width:760px;margin-inline:auto">
      {%- for block in section.blocks -%}
        {%- if block.type == 'content_block' -%}
          <div class="accordion-item" data-accordion-item {{ block.shopify_attributes }}>
            <button
              class="accordion-trigger"
              data-accordion-trigger
              aria-expanded="false"
              aria-controls="seo-body-{{ block.id }}">
              {{ block.settings.title }}
              <span class="accordion-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </span>
            </button>
            <div class="accordion-body" id="seo-body-{{ block.id }}" data-accordion-body>
              <div class="accordion-content">
                {{ block.settings.content }}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "SEO Content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "About Nefume Fragrances" }
  ],
  "blocks": [
    {
      "type": "content_block",
      "name": "Content block",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SEO Content",
      "blocks": [
        { "type": "content_block", "settings": { "title": "Premium Perfumes & Fragrances Online in India", "content": "<p>Nefume offers a curated collection of premium perfumes for men and women. Discover long-lasting Eau de Parfum, Eau de Toilette, and exclusive fragrance sets crafted from the finest ingredients.</p>" } },
        { "type": "content_block", "settings": { "title": "How to Choose the Right Fragrance", "content": "<p>Choosing a fragrance is deeply personal. Consider the fragrance family — floral, woody, oriental, or fresh — and test on your skin before purchasing. Our discovery kits let you sample before committing.</p>" } }
      ]
    }
  ]
}
{% endschema %}
