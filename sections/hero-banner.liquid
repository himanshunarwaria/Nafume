{{- 'hero.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign has_video   = section.settings.video != blank
  assign has_desktop = section.settings.desktop_image != blank
  assign has_mobile  = section.settings.mobile_image != blank

  assign overlay_opacity = section.settings.overlay_opacity | times: 0.01

  assign height_cls = 'hero--' | append: section.settings.min_height
  assign vpos_cls   = 'hero--v-' | append: section.settings.text_position
  assign align_cls  = 'hero--a-' | append: section.settings.text_align

  if has_desktop
    assign hero_src_750  = section.settings.desktop_image | image_url: width: 750
    assign hero_src_1100 = section.settings.desktop_image | image_url: width: 1100
    assign hero_src_1500 = section.settings.desktop_image | image_url: width: 1500
    assign hero_src_1920 = section.settings.desktop_image | image_url: width: 1920
  endif
-%}

{%- if has_desktop -%}
  <link rel="preload" as="image"
        imagesrcset="{{ hero_src_750 }} 750w, {{ hero_src_1100 }} 1100w, {{ hero_src_1500 }} 1500w, {{ hero_src_1920 }} 1920w"
        imagesizes="100vw">
{%- endif -%}

<section
  id="hero-{{ section.id }}"
  class="hero {{ height_cls }} {{ vpos_cls }} {{ align_cls }}"
  aria-label="{{ section.settings.heading | default: 'Hero banner' | escape }}"
  style="
    --hero-overlay:       {{ overlay_opacity }};
    --hero-overlay-color: {{ section.settings.overlay_color }};
    --hero-heading-color: {{ section.settings.heading_color }};
    --hero-text-color:    {{ section.settings.text_color }};
    --hero-eyebrow-color: {{ section.settings.eyebrow_color }};
  ">

  {%- comment -%} ───────────────────────────────────────
    LAYER 1 — Media (video + image, absolutely filled)
  ─────────────────────────────────────────────────── {%- endcomment -%}
  <div class="hero__media" aria-hidden="true">

    {%- if has_video -%}
      {{- section.settings.video | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        playsinline: true,
        preload: 'auto',
        class: 'hero__video'
      -}}
    {%- endif -%}

    {%- if has_desktop -%}
      <picture class="hero__picture">
        {%- if has_mobile -%}
          <source
            media="(max-width: 767px)"
            srcset="
              {{ section.settings.mobile_image | image_url: width: 750  }} 750w,
              {{ section.settings.mobile_image | image_url: width: 960  }} 960w,
              {{ section.settings.mobile_image | image_url: width: 1200 }} 1200w
            "
            sizes="100vw">
        {%- elsif has_video == false -%}
          {{- '' -}}
        {%- endif -%}
        <img
          src="{{ hero_src_1920 }}"
          srcset="{{ hero_src_750 }} 750w, {{ hero_src_1100 }} 1100w, {{ hero_src_1500 }} 1500w, {{ hero_src_1920 }} 1920w"
          sizes="100vw"
          class="hero__img"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="{{ section.settings.desktop_image.width }}"
          height="{{ section.settings.desktop_image.height }}"
          alt="{{ section.settings.desktop_image.alt | default: shop.name | escape }}">
      </picture>

    {%- elsif has_video == false -%}
      <div class="hero__img-fallback" aria-hidden="true"></div>
    {%- endif -%}

  </div>

  {%- comment -%} LAYER 2 — Overlay {%- endcomment -%}
  <div class="hero__overlay" aria-hidden="true"></div>

  {%- comment -%} ───────────────────────────────────────
    LAYER 3 — Content
  ─────────────────────────────────────────────────── {%- endcomment -%}
  <div class="hero__body">
    <div class="container">
      <div class="hero__text-wrap">

        {%- if section.settings.eyebrow != blank -%}
          <p class="hero__eyebrow">
            {%- if section.settings.eyebrow_style == 'rule' -%}
              <span class="hero__eyebrow-rule" aria-hidden="true"></span>
            {%- endif -%}
            {{ section.settings.eyebrow }}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="hero__heading">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="hero__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.cta_primary_label != blank
            or section.settings.cta_secondary_label != blank -%}
          <div class="hero__ctas">

            {%- if section.settings.cta_primary_label != blank -%}
              <a href="{{ section.settings.cta_primary_url | default: '#' }}"
                 class="hero-btn hero-btn--solid"
                 {% if section.settings.cta_primary_url == blank %}
                   tabindex="-1" aria-disabled="true"
                 {% endif %}>
                {{ section.settings.cta_primary_label }}
              </a>
            {%- endif -%}

            {%- if section.settings.cta_secondary_label != blank -%}
              <a href="{{ section.settings.cta_secondary_url | default: '#' }}"
                 class="hero-btn hero-btn--text"
                 {% if section.settings.cta_secondary_url == blank %}
                   tabindex="-1" aria-disabled="true"
                 {% endif %}>
                {{ section.settings.cta_secondary_label }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" aria-hidden="true" width="14" height="14">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            {%- endif -%}

          </div>
        {%- endif -%}

        {%- if section.settings.trust_strip != blank -%}
          <p class="hero__trust">{{ section.settings.trust_strip }}</p>
        {%- endif -%}

      </div>
    </div>
  </div>

  {%- comment -%} Scroll indicator {%- endcomment -%}
  {%- if section.settings.show_scroll_indicator -%}
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-line"></span>
      <span class="hero__scroll-label">Scroll</span>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Small label above the heading.",
      "default": "New Collection 2025"
    },
    {
      "type": "select",
      "id": "eyebrow_style",
      "label": "Eyebrow style",
      "options": [
        { "value": "text",  "label": "Text only" },
        { "value": "rule",  "label": "Text with leading rule" }
      ],
      "default": "rule"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "info": "Use H1 for the main homepage hero only.",
      "options": [
        { "value": "h1", "label": "H1 — page hero" },
        { "value": "h2", "label": "H2" }
      ],
      "default": "h1"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Wear Your Story"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Luxury fragrances crafted for the modern soul."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary link text",
      "default": "Discover the Collection"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary link URL"
    },
    {
      "type": "text",
      "id": "trust_strip",
      "label": "Trust strip",
      "info": "Short social-proof line shown below CTAs. E.g. ★ 4.8 from 2,000+ reviews · Free shipping ₹999+ · COD available",
      "default": "★ 4.8 from 2,000+ reviews · Free shipping ₹999+ · COD available"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended: 1920 × 1080px minimum. Also shown as video poster frame."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended: 750 × 1000px portrait crop. Falls back to desktop image if not set."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video",
      "info": "Autoplays muted + looped. Hides on mobile to preserve battery. Upload a 15–30s ambient MP4."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "min_height",
      "label": "Section height",
      "options": [
        { "value": "small",  "label": "Small — 60 vh" },
        { "value": "medium", "label": "Medium — 80 vh" },
        { "value": "large",  "label": "Full screen — 100 vh" },
        { "value": "auto",   "label": "Auto (content height)" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Vertical text position",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#0d0b08"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 85,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Typography colors"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#c9a96e"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#d8d2c8"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "eyebrow": "New Collection 2025",
        "heading": "Wear Your Story",
        "subheading": "Luxury fragrances crafted for the modern soul.",
        "cta_primary_label": "Shop Now",
        "cta_secondary_label": "Discover the Collection",
        "min_height": "large",
        "text_position": "center",
        "text_align": "center",
        "overlay_opacity": 35,
        "show_scroll_indicator": true
      }
    }
  ]
}
{% endschema %}
