<section class="hero" data-hero-slider data-autoplay="{{ section.settings.autoplay_speed | times: 1000 }}" aria-label="Hero banner">

  {%- for block in section.blocks -%}
    {%- if block.type == 'slide' -%}
      <div class="hero__slide{% if forloop.first %} is-active{% endif %}"
           data-slide
           {{ block.shopify_attributes }}>

        {%- if block.settings.image != blank -%}
          {%- if forloop.first -%}
            {{ block.settings.image | image_url: width: 1920 | image_tag:
              class: 'hero__img', loading: 'eager', fetchpriority: 'high',
              alt: block.settings.heading | default: shop.name, width: 1920, height: 1080 }}
          {%- else -%}
            {{ block.settings.image | image_url: width: 1920 | image_tag:
              class: 'hero__img', loading: 'lazy',
              alt: block.settings.heading | default: shop.name, width: 1920, height: 1080 }}
          {%- endif -%}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__img' }}
        {%- endif -%}

        <div class="hero__overlay"></div>

        <div class="hero__content">
          <div class="hero__text">
                {%- if block.settings.eyebrow != blank -%}
                  <p class="hero__eyebrow">{{ block.settings.eyebrow }}</p>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <h2 class="hero__title">{{ block.settings.heading }}</h2>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <p class="hero__desc">{{ block.settings.description }}</p>
                {%- endif -%}

                <div class="hero__ctas">
                  {%- if block.settings.btn_primary_text != blank -%}
                    <a href="{{ block.settings.btn_primary_url | default: '/collections/all' }}"
                       class="btn btn--lg" style="background:#fff;color:var(--clr-ink);border-color:#fff">
                      {{ block.settings.btn_primary_text }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.btn_secondary_text != blank -%}
                    <a href="{{ block.settings.btn_secondary_url | default: '/collections/all' }}"
                       class="btn btn--lg btn--outline-inv">
                      {{ block.settings.btn_secondary_text }}
                    </a>
                  {%- endif -%}
                </div>
              </div>
        </div>

      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- if section.blocks.size > 1 -%}
    <button class="hero__prev" aria-label="Previous slide">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <button class="hero__next" aria-label="Next slide">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
    <div class="hero__dots" role="tablist" aria-label="Slide controls">
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          <button class="hero__dot{% if forloop.first %} is-active{% endif %}"
                  role="tab"
                  aria-label="Go to slide {{ forloop.index }}"
                  aria-selected="{{ forloop.first }}"></button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s",
      "label": "Autoplay speed"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "New Collection" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Wear Your Story" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Premium fragrances crafted for every emotion." },
        { "type": "text", "id": "btn_primary_text", "label": "Primary button text", "default": "Shop Now" },
        { "type": "url", "id": "btn_primary_url", "label": "Primary button URL" },
        { "type": "text", "id": "btn_secondary_text", "label": "Secondary button text", "default": "Explore All" },
        { "type": "url", "id": "btn_secondary_url", "label": "Secondary button URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "slide", "settings": { "eyebrow": "New Launches 2025", "heading": "Wear Your Story", "description": "Premium fragrances crafted for every emotion.", "btn_primary_text": "Shop Now", "btn_secondary_text": "Explore All" } }
      ]
    }
  ],
  "max_blocks": 5
}
{% endschema %}
