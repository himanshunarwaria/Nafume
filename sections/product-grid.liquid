{{- 'product-card.css' | asset_url | stylesheet_tag -}}
{{- 'product-grid.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign col   = collections[section.settings.collection]
  assign limit = section.settings.product_limit | default: 8
  assign cols  = section.settings.columns_desktop | default: 4
  assign has_products = false
  if section.settings.collection != blank and col != blank and col.products.size > 0
    assign has_products = true
  endif
-%}

{%- if has_products or request.design_mode -%}

<section
  id="pg-{{ section.id }}"
  class="product-grid"
  style="--pg-cols: {{ cols }}; --pg-bg: {{ section.settings.bg_color }};"
  aria-labelledby="pg-{{ section.id }}-heading">

  <div class="pg__container container">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header class="pg__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="pg__eyebrow eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="pg__heading" id="pg-{{ section.id }}-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if has_products -%}
      <ul class="pg__grid" role="list">
        {%- for product in col.products limit: limit -%}
          <li class="pg__item">
            {%- render 'product-card',
              product:        product,
              image_ratio:    'portrait',
              lazy:           true,
              index:          forloop.index,
              show_quick_add: false,
              show_quick_view: false,
              show_desc:      false,
              show_sale_pct:  true
            -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <div class="pg__placeholder">
        <p>Select a collection in the section settings to display products here.</p>
      </div>
    {%- endif -%}

    {%- if section.settings.show_cta and section.settings.cta_label != blank -%}
      <div class="pg__cta-wrap">
        <a href="{{ section.settings.cta_url | default: col.url | default: '/collections/all' }}"
           class="btn btn--outline">
          {{ section.settings.cta_label }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="14" height="14">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>

</section>

{%- endif -%}

{% schema %}
{
  "name": "Product Grid",
  "tag": "div",
  "class": "product-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "New Launches"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Max products to show",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Product Grid",
      "settings": {
        "heading": "New Launches",
        "product_limit": 8,
        "columns_desktop": "4"
      }
    },
    {
      "name": "Best Sellers Grid",
      "settings": {
        "heading": "Best Sellers",
        "product_limit": 8,
        "columns_desktop": "4"
      }
    }
  ]
}
{% endschema %}
