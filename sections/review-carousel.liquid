        },
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Divya R.",
            "review_title": "Worth every rupee",
            "review_text": "I was hesitant about the price point but after wearing this for a week I completely understand it. The depth and evolution of the scent throughout the day is something I haven't found elsewhere at this price.",
            "rating": 5,
            "verified": true,
            "review_date": "January 2025"
          }
