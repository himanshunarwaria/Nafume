{{- 'footer.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign logo         = section.settings.logo
  assign logo_width   = section.settings.logo_width | default: 120
  assign tagline      = section.settings.brand_tagline
  assign s_head       = section.settings.support_heading   | default: 'Support'
  assign o_head       = section.settings.orders_heading    | default: 'Orders & Shipping'
  assign g_head       = section.settings.grievance_heading | default: 'Consumer Grievance'
  assign cr_year      = 'now' | date: '%Y'
  assign copyright    = section.settings.copyright_text | default: '© {year} Nefume. All rights reserved.' | replace: '{year}', cr_year
-%}

<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  <div class="footer__inner">

    {%- comment -%} ── Top: Brand left · Newsletter right ─────── {%- endcomment -%}
    <div class="footer__top">

      <div class="footer__brand">
        {%- if logo != blank -%}
          <a href="{{ routes.root_url }}" class="footer__brand-logo" aria-label="{{ shop.name }}">
            {{- logo | image_url: width: logo_width
                     | image_tag: width: logo_width, loading: 'lazy', alt: shop.name -}}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer__brand-name">{{ shop.name }}</a>
        {%- endif -%}

        {%- if tagline != blank -%}
          <p class="footer__brand-tagline">{{ tagline }}</p>
        {%- endif -%}

        {%- render 'social-icons',
            instagram: section.settings.social_instagram,
            facebook:  section.settings.social_facebook,
            youtube:   section.settings.social_youtube,
            twitter:   section.settings.social_twitter,
            size: 18 -%}
      </div>

      <div class="footer__newsletter">
        {%- if section.settings.newsletter_eyebrow != blank -%}
          <p class="footer__nsl-eyebrow">{{ section.settings.newsletter_eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.newsletter_heading != blank -%}
          <h2 class="footer__nsl-heading">{{ section.settings.newsletter_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.newsletter_sub != blank -%}
          <p class="footer__nsl-sub">{{ section.settings.newsletter_sub }}</p>
        {%- endif -%}

        {%- form 'customer', id: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__nsl-row">
            <label for="footer-nsl-email" class="visually-hidden">
              {{- section.settings.newsletter_placeholder | default: 'Your email address' -}}
            </label>
            <input
              id="footer-nsl-email"
              type="email"
              name="contact[email]"
              class="footer__nsl-input"
              placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email address' | escape }}"
              autocomplete="email"
              required>
            <button type="submit" class="footer__nsl-btn">
              {{- section.settings.newsletter_btn | default: 'Subscribe' | escape -}}
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="footer__nsl-success" role="status">
              {{ section.settings.newsletter_success | default: 'Thank you — you\'re subscribed!' }}
            </p>
          {%- endif -%}
        {%- endform -%}

        {%- if section.settings.newsletter_disclaimer != blank -%}
          <p class="footer__nsl-disclaimer">{{ section.settings.newsletter_disclaimer }}</p>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} ── Mid: Link columns + Grievance ─────────── {%- endcomment -%}
    <div class="footer__mid">

      {%- comment -%} Support column {%- endcomment -%}
      <div class="footer__col" data-footer-col>
        <p class="footer__col-heading">{{ s_head }}</p>
        <button
          class="footer__col-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="footer-support-{{ section.id }}">
          {{- s_head }}
          <span class="footer__chevron" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" width="14" height="14">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </span>
        </button>
        <ul class="footer__col-links" id="footer-support-{{ section.id }}">
          {%- if section.settings.support_link_1_label != blank -%}
            <li>
              <a href="{{ section.settings.support_link_1_url | default: '#' }}">
                {{- section.settings.support_link_1_label -}}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.support_link_2_label != blank -%}
            <li>
              <a href="{{ section.settings.support_link_2_url | default: '#' }}">
                {{- section.settings.support_link_2_label -}}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.support_link_3_label != blank -%}
            <li>
              <a href="{{ section.settings.support_link_3_url | default: '#' }}">
                {{- section.settings.support_link_3_label -}}
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Orders & Shipping column {%- endcomment -%}
      <div class="footer__col" data-footer-col>
        <p class="footer__col-heading">{{ o_head }}</p>
        <button
          class="footer__col-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="footer-orders-{{ section.id }}">
          {{- o_head }}
          <span class="footer__chevron" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" width="14" height="14">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </span>
        </button>
        <ul class="footer__col-links" id="footer-orders-{{ section.id }}">
          {%- if section.settings.orders_link_1_label != blank -%}
            <li>
              <a href="{{ section.settings.orders_link_1_url | default: '/policies/privacy-policy' }}">
                {{- section.settings.orders_link_1_label -}}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.orders_link_2_label != blank -%}
            <li>
              <a href="{{ section.settings.orders_link_2_url | default: '/policies/refund-policy' }}">
                {{- section.settings.orders_link_2_label -}}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.orders_link_3_label != blank -%}
            <li>
              <a href="{{ section.settings.orders_link_3_url | default: '/policies/shipping-policy' }}">
                {{- section.settings.orders_link_3_label -}}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.orders_link_4_label != blank -%}
            <li>
              <a href="{{ section.settings.orders_link_4_url | default: '#' }}">
                {{- section.settings.orders_link_4_label -}}
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Grievance / Contact block {%- endcomment -%}
      <div class="footer__grievance">
        <p class="footer__grievance-heading">{{ g_head }}</p>

        {%- if section.settings.grievance_officer != blank -%}
          <p class="footer__grievance-officer">{{ section.settings.grievance_officer | escape }}</p>
        {%- endif -%}

        <ul class="footer__grievance-list">

          {%- if section.settings.grievance_email != blank -%}
            <li class="footer__grievance-item">
              <span class="footer__grievance-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" width="14" height="14">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="M2 7l10 7 10-7"/>
                </svg>
              </span>
              <span class="footer__grievance-text">
                <a href="mailto:{{ section.settings.grievance_email }}">
                  {{- section.settings.grievance_email -}}
                </a>
              </span>
            </li>
          {%- endif -%}

          {%- if section.settings.grievance_phone != blank -%}
            <li class="footer__grievance-item">
              <span class="footer__grievance-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" width="14" height="14">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.1 6.1l1.08-.99a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </span>
              <span class="footer__grievance-text">
                <a href="tel:{{ section.settings.grievance_phone | remove: ' ' | remove: '-' }}">
                  {{- section.settings.grievance_phone -}}
                </a>
              </span>
            </li>
          {%- endif -%}

          {%- if section.settings.grievance_address != blank -%}
            <li class="footer__grievance-item">
              <span class="footer__grievance-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" width="14" height="14">
                  <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              <span class="footer__grievance-text">
                {{- section.settings.grievance_address | escape | newline_to_br -}}
              </span>
            </li>
          {%- endif -%}

        </ul>

        {%- if section.settings.grievance_response != blank -%}
          <p class="footer__grievance-response">{{ section.settings.grievance_response | escape }}</p>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} ── Bottom: Copyright · Payment icons ─────── {%- endcomment -%}
    <div class="footer__bottom">
      <p class="footer__copyright">{{ copyright }}</p>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment-icons" aria-label="Accepted payment methods">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</footer>

<script>
(function () {
  'use strict';
  function initFooterAccordion() {
    document.querySelectorAll('[data-footer-col]').forEach(function (col) {
      var btn  = col.querySelector('.footer__col-toggle');
      var body = col.querySelector('.footer__col-links');
      if (!btn || !body) return;
      btn.addEventListener('click', function () {
        var open = col.classList.contains('is-open');
        if (open) {
          col.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
          body.style.maxHeight = '0';
        } else {
          col.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
          body.style.maxHeight = body.scrollHeight + 'px';
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooterAccordion);
  } else {
    initFooterAccordion();
  }
})();
</script>

