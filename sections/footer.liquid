<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer__top">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="footer__brand">
        <div class="footer__logo">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 160 | image_tag: loading: 'lazy', alt: shop.name }}
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </div>
        {%- if section.settings.brand_description != blank -%}
          <p class="footer__about">{{ section.settings.brand_description }}</p>
        {%- endif -%}

        <div class="footer__social">
          {%- if section.settings.social_instagram != blank -%}
            <a href="{{ section.settings.social_instagram }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_youtube != blank -%}
            <a href="{{ section.settings.social_youtube }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75,15.02 15.5,12 9.75,8.98 9.75,15.02"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Link columns from blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer__col" {{ block.shopify_attributes }}>
            <h3 class="footer__col-title">{{ block.settings.heading }}</h3>
            <ul class="footer__links" role="list">
              {%- for link in block.settings.menu.links -%}
                <li><a class="footer__link" href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- comment -%} Footer bottom bar {%- endcomment -%}
    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>

      <div class="footer__payment-icons" aria-label="Accepted payment methods">
        {%- comment -%} SVG payment icons placeholder {%- endcomment -%}
        <svg viewBox="0 0 38 24" aria-label="Visa">
          <rect width="38" height="24" rx="4" fill="#1A1F71" opacity=".07" stroke="#e5e0d8" stroke-width="1"/>
          <text x="50%" y="60%" text-anchor="middle" fill="#1A1F71" font-size="9" font-family="Arial" font-weight="bold">VISA</text>
        </svg>
        <svg viewBox="0 0 38 24" aria-label="Mastercard">
          <rect width="38" height="24" rx="4" fill="#252525" opacity=".07" stroke="#e5e0d8" stroke-width="1"/>
          <circle cx="15" cy="12" r="7" fill="#EB001B" opacity=".8"/>
          <circle cx="23" cy="12" r="7" fill="#F79E1B" opacity=".8"/>
        </svg>
        <svg viewBox="0 0 38 24" aria-label="UPI">
          <rect width="38" height="24" rx="4" fill="#097939" opacity=".07" stroke="#e5e0d8" stroke-width="1"/>
          <text x="50%" y="62%" text-anchor="middle" fill="#097939" font-size="8" font-family="Arial" font-weight="bold">UPI</text>
        </svg>
        <svg viewBox="0 0 38 24" aria-label="COD">
          <rect width="38" height="24" rx="4" fill="#1a1a1a" opacity=".07" stroke="#e5e0d8" stroke-width="1"/>
          <text x="50%" y="62%" text-anchor="middle" fill="#1a1a1a" font-size="7" font-family="Arial" font-weight="bold">COD</text>
        </svg>
      </div>

      <div style="display:flex;gap:1rem;flex-wrap:wrap">
        <a href="/policies/privacy-policy" class="footer__link">Privacy Policy</a>
        <a href="/policies/terms-of-service" class="footer__link">Terms</a>
        <a href="/policies/refund-policy" class="footer__link">Returns</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Crafted for those who wear their mood. Nefume brings you a curated collection of fine fragrances inspired by nature, art, and emotion."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
    { "type": "url", "id": "social_facebook", "label": "Facebook URL" },
    { "type": "url", "id": "social_youtube", "label": "YouTube URL" }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Shop" } },
        { "type": "link_list", "settings": { "heading": "Help" } },
        { "type": "link_list", "settings": { "heading": "Company" } }
      ]
    }
  ]
}
{% endschema %}
