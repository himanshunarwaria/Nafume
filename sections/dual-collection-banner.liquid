{{- 'hero.css' | asset_url | stylesheet_tag -}}

{%- if section.blocks.size > 0 -%}

<section
  id="dual-banner-{{ section.id }}"
  class="dual-banner"
  aria-label="{{ section.settings.section_label | default: 'Collections' | escape }}">

  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="dual-banner__intro">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="dual-banner__grid dual-banner__grid--gap-{{ section.settings.gap }}">

    {%- for block in section.blocks -%}
      {%- liquid
        assign card_overlay = block.settings.overlay_opacity | times: 0.01
        assign has_image = false
        if block.settings.image != blank
          assign has_image = true
        endif
        assign card_cls     = 'collection-card collection-card--' | append: block.settings.card_height
        assign content_cls  = 'collection-card__content collection-card__content--' | append: block.settings.content_align
      -%}

      <article
        class="{{ card_cls }}"
        {{ block.shopify_attributes }}
        style="
          --card-overlay:       {{ card_overlay }};
          --card-overlay-color: {{ block.settings.overlay_color }};
          --card-text:          {{ block.settings.text_color }};
        ">

        {%- comment -%} Background image {%- endcomment -%}
        <div class="collection-card__media" aria-hidden="true">

          {%- if has_image -%}
            {%- assign dc_img_alt = block.settings.image.alt | default: block.settings.title | escape -%}
            {{- block.settings.image
              | image_url: width: 960
              | image_tag:
                class: 'collection-card__img',
                loading: 'lazy',
                alt: dc_img_alt,
                sizes: '(max-width: 767px) 100vw, 50vw',
                widths: '400,600,800,960,1200'
            -}}
          {%- else -%}
            <div class="collection-card__img-fallback"></div>
          {%- endif -%}

          <div class="collection-card__overlay"></div>
        </div>

        {%- comment -%} Content {%- endcomment -%}
        <div class="{{ content_cls }}">

          {%- if block.settings.eyebrow != blank -%}
            <p class="collection-card__eyebrow">{{ block.settings.eyebrow }}</p>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="collection-card__title">{{ block.settings.title }}</h3>
          {%- endif -%}

          {%- if block.settings.subtitle != blank -%}
            <p class="collection-card__subtitle">{{ block.settings.subtitle }}</p>
          {%- endif -%}

          {%- if block.settings.cta_label != blank -%}
            <a href="{{ block.settings.cta_url | default: '#' }}"
               class="collection-card__cta"
               aria-label="{{ block.settings.cta_label }} — {{ block.settings.title }}">
              {{ block.settings.cta_label }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.5" aria-hidden="true" width="14" height="14">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          {%- endif -%}

        </div>

        {%- comment -%} Full-card link overlay (accessible) {%- endcomment -%}
        {%- if block.settings.cta_url != blank -%}
          <a href="{{ block.settings.cta_url }}"
             class="collection-card__link-overlay"
             tabindex="-1"
             aria-hidden="true"></a>
        {%- endif -%}

      </article>
    {%- endfor -%}

  </div>

</section>

{%- endif -%}

{% schema %}
{
  "name": "Dual Collection Banner",
  "tag": "section",
  "class": "dual-banner-section",
  "max_blocks": 2,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "section_label",
      "label": "Section aria-label",
      "info": "Screen reader label for the section.",
      "default": "Shop by Collection"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Optional label shown above the section heading."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "info": "Optional heading above the two cards."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Gap between cards",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs",   "label": "2 px" },
        { "value": "sm",   "label": "12 px" },
        { "value": "md",   "label": "24 px" },
        { "value": "lg",   "label": "40 px" }
      ],
      "default": "xs"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image",
          "info": "Recommended: 960 × 1200 px. Portrait ratio works best."
        },
        {
          "type": "select",
          "id": "card_height",
          "label": "Card height",
          "options": [
            { "value": "short",  "label": "Short — 55 vh" },
            { "value": "medium", "label": "Medium — 70 vh" },
            { "value": "tall",   "label": "Tall — 85 vh" }
          ],
          "default": "tall"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Discover the collection"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA text",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA link"
        },
        {
          "type": "select",
          "id": "content_align",
          "label": "Content position",
          "options": [
            { "value": "top-left",      "label": "Top — Left" },
            { "value": "top-center",    "label": "Top — Center" },
            { "value": "top-right",     "label": "Top — Right" },
            { "value": "center-left",   "label": "Center — Left" },
            { "value": "center",        "label": "Center — Center" },
            { "value": "center-right",  "label": "Center — Right" },
            { "value": "bottom-left",   "label": "Bottom — Left" },
            { "value": "bottom-center", "label": "Bottom — Center" },
            { "value": "bottom-right",  "label": "Bottom — Right" }
          ],
          "default": "bottom-left"
        },
        {
          "type": "header",
          "content": "Overlay"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#0d0b08"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 30
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dual Collection Banner",
      "settings": {
        "gap": "xs"
      },
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "For Him",
            "subtitle": "Bold. Intense. Unforgettable.",
            "cta_label": "Explore",
            "card_height": "tall",
            "overlay_opacity": 30,
            "content_align": "bottom-left"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "For Her",
            "subtitle": "Floral. Sensual. Timeless.",
            "cta_label": "Explore",
            "card_height": "tall",
            "overlay_opacity": 30,
            "content_align": "bottom-left"
          }
        }
      ]
    }
  ]
}
{% endschema %}
